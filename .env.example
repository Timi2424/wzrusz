# Local dev — copy to .env (gitignored):  cp .env.example .env
# Requires: npm run db:up  (Docker Postgres on host port 5433)
#
# Staging DB:  GitHub Actions deploy-api.yml (secret DATABASE_URL)
# Staging app: push main → EB (APP_ENV + DATABASE_URL in AWS console)

APP_ENV=local
PORT=3000
HOST=0.0.0.0
CORS_ORIGIN=http://localhost:4200

DATABASE_URL=postgresql://wzrusz:wzrusz@localhost:5433/wzrusz_dev

