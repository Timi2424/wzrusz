# Local dev — copy to .env (gitignored):  cp .env.example .env
# Requires: npm run db:up  (Docker Postgres on host port 5433)
#
# Staging DB:  migrations on EB postdeploy (DATABASE_URL in EB env)
# Staging app: push main → EB (APP_ENV + DATABASE_URL in AWS console)

APP_ENV=local
PORT=3000
HOST=0.0.0.0
CORS_ORIGIN=http://localhost:4200

DATABASE_URL=postgresql://wzrusz:wzrusz@localhost:5433/wzrusz_dev

# JWT for admin auth (required on staging/production)
# JWT_SECRET=change-me-in-staging

# Seed admin (migration): admin@wzrusz.local / changeme

# Email (F-04) — local uses stub logs; staging/production use SES when configured
# EMAIL_MODE=stub
# EMAIL_MODE=ses
# SES_FROM_EMAIL=noreply@twoja-domena.pl
# ADMIN_NOTIFY_EMAIL=admin@twoja-domena.pl
# AWS_REGION=eu-central-1
# On EB: attach IAM policy ses:SendEmail to instance role; verify domain in SES console

# Media (F-03) — local uses stub (files in .local-media/, served at /api/media/…)
# MEDIA_MODE=stub
# MEDIA_MODE=s3
# S3_MEDIA_BUCKET=wzrusz-media-staging
# S3_MEDIA_PREFIX=decorations
# On EB: attach IAM policy s3:PutObject/GetObject on bucket prefix to instance role

# NX_API_URL=http://localhost:3000
